{
  "manifest_version": 2,
  "version": "1.0.0",
  "icon": "images/image.png",

  "name": "EstensioneHTML",
  "description": "L'idea è quella di estrarre HTML da una pagina web",

  "browser_action": {
    "default_popup": "index.html"
  },
  "permissions": ["tabs", "<all_urls>"],

  "background": {
    "scripts": ["index.js"],
    "persistent": false
  }
}
